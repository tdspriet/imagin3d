import os
from urllib.parse import urlparse

import torch
import imageio
from PIL import Image

# Set environment variables before importing Trellis to ensure dependencies 
# (like spconv) pick up the configurations during initialization.
os.environ['SPCONV_ALGO'] = 'native'
os.environ['U2NET_HOME'] = '{{ offline_path }}/vendor/u2net'
os.environ['TORCH_HOME'] = '{{ offline_path }}/vendor/torch_hub'

from trellis.pipelines import TrellisImageTo3DPipeline
from trellis.utils import render_utils, postprocessing_utils


def patch_torch_hub_for_offline_dinov2(offline_path: str):
    """Routes DINOv2 repo and checkpoints to the backend-local offline bundle."""
    dinov2_repo = os.path.join(offline_path, 'vendor', 'torch_hub', 'facebookresearch_dinov2_main')
    checkpoints_dir = os.path.join(offline_path, 'vendor', 'torch_hub', 'checkpoints')

    if not os.path.isdir(dinov2_repo) or not os.path.isdir(checkpoints_dir):
        return

    torch.hub.set_dir(os.environ['TORCH_HOME'])
    original_torch_hub_load = torch.hub.load
    original_load_state_dict_from_url = torch.hub.load_state_dict_from_url

    def _offline_torch_hub_load(repo_or_dir, model, *args, **kwargs):
        if repo_or_dir == 'facebookresearch/dinov2':
            kwargs.pop('source', None)
            return original_torch_hub_load(
                dinov2_repo,
                model,
                *args,
                source='local',
                **kwargs,
            )
        return original_torch_hub_load(repo_or_dir, model, *args, **kwargs)

    def _offline_load_state_dict_from_url(url, *args, **kwargs):
        checkpoint_name = kwargs.get('file_name') or os.path.basename(urlparse(url).path)
        checkpoint_path = os.path.join(checkpoints_dir, checkpoint_name)
        if not os.path.isfile(checkpoint_path):
            raise FileNotFoundError(
                f"Missing offline checkpoint for {url}: {checkpoint_path}"
            )
        map_location = kwargs.get('map_location', 'cpu')
        return torch.load(checkpoint_path, map_location=map_location)

    torch.hub.load = _offline_torch_hub_load
    torch.hub.load_state_dict_from_url = _offline_load_state_dict_from_url


def main():
    # 1. Define configuration and template paths
    offline_path = "{{ offline_path }}"
    image_path = "{{ image_path }}"
    output_video_gs = "{{ output_video_gs }}"
    output_video_rf = "{{ output_video_rf }}"
    output_video_mesh = "{{ output_video_mesh }}"
    output_glb = "{{ output_glb }}"
    output_ply = "{{ output_ply }}"

    # 2. Setup offline routing
    patch_torch_hub_for_offline_dinov2(offline_path)

    # 3. Load the pipeline and image
    pipeline = TrellisImageTo3DPipeline.from_pretrained(offline_path)
    pipeline.cuda()
    image = Image.open(image_path)

    # 4. Run the pipeline
    outputs = pipeline.run(
        image,
        seed=1,
        sparse_structure_sampler_params={
            "steps": 12,
            "cfg_strength": 7.5,
        },
        slat_sampler_params={
            "steps": 12,
            "cfg_strength": 3.0, 
        },
    )

    # 5. Extract outputs to avoid repetitive dictionary lookups
    gaussian_output = outputs['gaussian'][0]
    radiance_field_output = outputs['radiance_field'][0]
    mesh_output = outputs['mesh'][0]

    # 6. Render and save videos
    gs_video = render_utils.render_video(gaussian_output)['color']
    imageio.mimsave(output_video_gs, gs_video, fps=30)

    rf_video = render_utils.render_video(radiance_field_output)['color']
    imageio.mimsave(output_video_rf, rf_video, fps=30)

    mesh_video = render_utils.render_video(mesh_output)['normal']
    imageio.mimsave(output_video_mesh, mesh_video, fps=30)

    # 7. Extract and save GLB file
    glb = postprocessing_utils.to_glb(
        gaussian_output,
        mesh_output,
        simplify=0.95,
        texture_size=1024,
    )
    glb.export(output_glb)

    # 8. Save Gaussians as PLY files
    gaussian_output.save_ply(output_ply)


if __name__ == "__main__":
    main()
